# ADR 0034 A/B shared config — copy to .leibniz-ab/ab_config.env and fill in.
# Sourced by scripts/run_organic_ab.sh so BOTH arms (A tonight, B tomorrow) use the IDENTICAL
# prover/panel/repair config — the only difference between the arms must be the code.
#
# NO SECRETS HERE. API keys stay in .env (ANTHROPIC_API_KEY, OPENROUTER_API_KEY, ...). This file
# is gitignored; only this .example template ships.
#
# Operator decision (2026-06-24): DROP the dead deepseek-prover-v2 (it 404s on OpenRouter).
# Base prover = opus alone; promulgation rides the 3-model repair panel below — which is exactly
# how organic5 actually worked (deepseek was already dead there), just without paying for the
# dead calls. Keep this IDENTICAL across both arms (the point of sourcing one file).

# Base prover ensemble (ADR 0028 `model@gateway` syntax allowed).
export LEIBNIZ_PROVER_MODELS="anthropic/claude-opus-4-8"

# N+1 consensus: a promulgation needs this many DISTINCT model identities closing the same goal.
export LEIBNIZ_PROOF_CONSENSUS="2"

# ADR 0029 agentic repair loop on (>0 enables it).
export LEIBNIZ_PROOF_REPAIR="1"

# ADR 0029 repair panel — the distinct frontier reasoners that carry promulgation to N+1=2
# (base is opus-only, so one panel model + opus = 2 distinct closers). These are ALWAYS routed
# through OpenRouter (assembly.py passes each slug straight to OpenRouterProvider — the panel does
# NOT honor `@gateway`/ADR 0028), so they must be OpenRouter-routable ids, and OPENROUTER_API_KEY
# must be set in .env (it is). Operator decision (2026-06-24): the vetted default trio — the same
# slugs already wired as the reasoner-failover defaults, so they are known-good.
export LEIBNIZ_REPAIR_PANEL="z-ai/glm-5.2,moonshotai/kimi-k2.6,openai/gpt-5.5"

# Optional: reasoner failover backups (ADR 0029, sequential failover for the opus PRIMARY repairer
# on an Anthropic outage). Defaults to the same trio; leave unset to keep that default.
# export LEIBNIZ_REASONER_FALLBACKS=""
