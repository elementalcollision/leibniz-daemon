# ADR 0034 A/B shared config — copy to .leibniz-ab/ab_config.env and fill in.
# Sourced by scripts/run_organic_ab.sh so BOTH arms (A tonight, B tomorrow) use the IDENTICAL
# prover/panel/repair config — the only difference between the arms must be the code.
#
# NO SECRETS HERE. API keys stay in .env (ANTHROPIC_API_KEY, OPENROUTER_API_KEY, ...). This file
# is gitignored; only this .example template ships.
#
# These values reproduce organic5's setup (see /tmp/organic5_run.log). NOTE: organic5's base
# ensemble listed deepseek/deepseek-prover-v2 twice, but that model 404s on OpenRouter (dead) —
# so the base ensemble was effectively opus-only and every promulgation rode the repair panel.
# That confound is HARMLESS for this A/B *as long as A and B share it*, but you may prefer to
# drop deepseek and list a live base prover instead. Whatever you choose, keep it identical
# across both arms (that is the whole point of sourcing one file).

# Base prover ensemble (ADR 0028 `model@gateway` syntax allowed).
export LEIBNIZ_PROVER_MODELS="deepseek/deepseek-prover-v2,deepseek/deepseek-prover-v2,anthropic/claude-opus-4-8"

# N+1 consensus: a promulgation needs this many DISTINCT model identities closing the same goal.
export LEIBNIZ_PROOF_CONSENSUS="2"

# ADR 0029 agentic repair loop on (>0 enables it).
export LEIBNIZ_PROOF_REPAIR="1"

# ADR 0029 repair panel — the distinct frontier reasoners that carry promulgation. organic5 used
# THREE (panel size 3): claude-opus + two OpenRouter frontier reasoners. Fill with the exact
# slugs you ran (e.g. anthropic/claude-opus-4-8,openai/gpt-5.5@openrouter,zhipu/glm-5.2@openrouter).
export LEIBNIZ_REPAIR_PANEL=""

# Optional: reasoner failover backups (ADR 0029) + per-gateway routing (ADR 0028). Leave unset to
# use defaults. If you route a panel model through a gateway, set its URL + key-env NAME here, e.g.:
#   export LEIBNIZ_GATEWAY_OPENROUTER_URL="https://openrouter.ai/api/v1"
#   export LEIBNIZ_GATEWAY_OPENROUTER_KEY_ENV="OPENROUTER_API_KEY"
# export LEIBNIZ_REASONER_FALLBACKS=""
