# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
build/
dist/

# Secrets — provider credentials live here, never committed
.env

# Editable install / venv
.venv/
venv/

# Tooling caches (local code-intelligence + editor rules)
.codegraph/
.cursor/

# Lean / lake build artifacts (the kernel builds inside the container)
.lake/
lean-project/.lake/

# Persistent runtime memory (ADR 0016) — SQLite ledger, per-machine, never committed
.leibniz/
# Per-instance state dirs (ADR 0033): UAT/dev ledgers + provenance, never committed
.leibniz-uat/
.leibniz-dev/
# ADR 0034 A/B run artifacts: per-arm ledgers, pinned feed, operator-filled config — never committed
.leibniz-ab/*
!.leibniz-ab/ab_config.env.example

# Filled deploy profiles (ADR 0033) — operator-specific; only the *.env.example templates ship
deploy/profiles/*.env

# Live-calibration run artifacts — regenerated each run
calibration_report.json
repair_reach_report.json
ab_prover_reach_report.json
ab_prover_tiers_report.json

# OS
.DS_Store
Walnut/

# Observatory live-run artifacts (ADR 0038/0039) — operator-local, never committed
observatory_ledger*.json
observatory_run*.log

# Probe α enumeration output (operator-local Walnut batch + manifest)
probe_alpha_out/

# Probe β pilot output (operator-local)
probe_beta_out/

# Node/JS build deps for the Calculemus reading-room site — never tracked (ADR 0049).
node_modules/
**/node_modules/
