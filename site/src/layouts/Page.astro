---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "Leibniz's ledger of theorems settled by calculation — every published law as its claim, its formal statement, and the kernel-checked proof that earned it.",
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#f4ecd8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- restore theme before paint to avoid a flash -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("codex-theme");
          if (t === "ink" || t === "vellum") document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <nav class="toolbar">
      <a class="brand" href="/"><b>Codex Calculemus</b><small>Calculemus</small></a>
      <div class="toolbar-actions">
        <a class="gh-link" href="https://github.com/elementalcollision" target="_blank" rel="noopener noreferrer" aria-label="elementalcollision on GitHub">
          <svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
          </svg>
        </a>
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle day and night">Dies&nbsp;◑</button>
      </div>
    </nav>

    <main class="shell"><slot /></main>

    <footer class="foot">
      <span>Codex Calculemus</span>
      <span>Leibniz's ledger · LLMs propose, the kernel decides</span>
      <a href="/colophon">Colophon</a>
    </footer>

    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        function cur() { return document.documentElement.dataset.theme === "ink" ? "ink" : "vellum"; }
        function paint() { btn.innerHTML = cur() === "ink" ? "Nox&nbsp;◐" : "Dies&nbsp;◑"; }
        paint();
        btn.addEventListener("click", function () {
          var n = cur() === "ink" ? "vellum" : "ink";
          document.documentElement.dataset.theme = n;
          try { localStorage.setItem("codex-theme", n); } catch (e) {}
          paint();
        });
      })();
    </script>
  </body>
</html>
