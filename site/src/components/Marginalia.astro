---
// Geometer's marginalia — austere SVG devices that re-skin with the vellum/ink
// theme (every colour is a CSS variable). Chosen deterministically per page by
// `figureFor()` in lib/format. No bitmap assets; the figures ARE the ornament.
interface Props {
  id: string;
  caption: string;
}
const { id, caption } = Astro.props;
---
<figure class="marginalia marginalia--figure">
  <svg viewBox="0 0 120 120" role="img" aria-label={caption} class="device">
    {id === "lemniscate" && (
      <path d="M60 60 C40 40, 20 40, 20 60 C20 80, 40 80, 60 60 C80 40, 100 40, 100 60 C100 80, 80 80, 60 60 Z"
            fill="none" stroke="var(--rubric)" stroke-width="1.4" />
    )}
    {id === "integral" && (
      <g>
        <path d="M74 24 C74 16, 56 16, 54 34 C50 60, 60 70, 56 96 C54 108, 38 108, 40 98"
              fill="none" stroke="var(--rubric)" stroke-width="2" stroke-linecap="round" />
        <path d="M44 44 L84 44 M40 76 L80 76" stroke="var(--ink-faint)" stroke-width="1" />
      </g>
    )}
    {id === "binary" && (
      <g class="device-text">
        <text x="60" y="34" text-anchor="middle">0 · 1</text>
        <text x="60" y="58" text-anchor="middle">1 · 10</text>
        <text x="60" y="82" text-anchor="middle">10 · 11</text>
        <line x1="28" y1="42" x2="92" y2="42" stroke="var(--ink-faint)" stroke-width="0.8" />
        <line x1="28" y1="66" x2="92" y2="66" stroke="var(--ink-faint)" stroke-width="0.8" />
      </g>
    )}
    {id === "sector" && (
      <g fill="none" stroke="var(--rubric)" stroke-width="1.3">
        <circle cx="60" cy="60" r="40" stroke="var(--ink-faint)" />
        <path d="M60 60 L100 60 A40 40 0 0 0 72 23 Z" fill="color-mix(in srgb, var(--rubric) 10%, transparent)" />
        <line x1="60" y1="60" x2="100" y2="60" />
        <line x1="60" y1="60" x2="72" y2="23" />
      </g>
    )}
    {id === "lattice" && (
      <g stroke="var(--rubric)" stroke-width="1.2" fill="var(--paper)">
        <line x1="60" y1="24" x2="32" y2="60" /><line x1="60" y1="24" x2="88" y2="60" />
        <line x1="32" y1="60" x2="60" y2="96" /><line x1="88" y1="60" x2="60" y2="96" />
        <line x1="60" y1="24" x2="60" y2="96" stroke="var(--ink-faint)" />
        <circle cx="60" cy="24" r="5" /><circle cx="32" cy="60" r="5" />
        <circle cx="88" cy="60" r="5" /><circle cx="60" cy="96" r="5" />
      </g>
    )}
    {id === "tree" && (
      <g stroke="var(--rubric)" stroke-width="1.2" fill="var(--paper)">
        <line x1="60" y1="22" x2="34" y2="56" /><line x1="60" y1="22" x2="86" y2="56" />
        <line x1="34" y1="56" x2="22" y2="92" /><line x1="34" y1="56" x2="46" y2="92" />
        <line x1="86" y1="56" x2="74" y2="92" /><line x1="86" y1="56" x2="98" y2="92" />
        <circle cx="60" cy="22" r="5" />
        <circle cx="34" cy="56" r="5" /><circle cx="86" cy="56" r="5" />
        <circle cx="22" cy="92" r="4" /><circle cx="46" cy="92" r="4" />
        <circle cx="74" cy="92" r="4" /><circle cx="98" cy="92" r="4" />
      </g>
    )}
  </svg>
  <figcaption>{caption}</figcaption>
</figure>

<style>
  .marginalia--figure .device { width: 100%; height: auto; opacity: 0.92; }
  .device-text text {
    font-family: var(--font-mono);
    font-size: 13px;
    fill: var(--ink-soft);
  }
</style>
