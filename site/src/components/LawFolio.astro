---
// The reader for one published law — the Propositio triad as a folio:
//   Enuntiatio  (the claim, in prose)
//   Expressio   (the formal statement, in the characteristica — Lean 4)
//   Demonstratio(the kernel-checked proof)
// sealed by the certificate. Q.E.D. is shown iff the kernel verified it.
import { claimLabel } from "../lib/format";

interface Law {
  statement: string;
  claim_type: string;
  falsifiable_claim: string;
  domain: string;
  theorem_src: string;
  proof_src: string;
  imports: string[];
  qed: string;
  kernel_verified: boolean;
  consensus: number;
  specimen: boolean;
}
const { law } = Astro.props as { law: Law };
const verified = law.kernel_verified && law.qed === "Q.E.D.";
const importLines = (law.imports || []).map((m) => `import ${m}`).join("\n");
const expressio = (importLines ? importLines + "\n\n" : "") + law.theorem_src;
---
<article class="law">
  <div class="law-meta">
    <span class="rubric">{claimLabel(law.claim_type)}</span>
    {law.domain && <><span class="sep">·</span><span>{law.domain.replace(/_/g, " ")}</span></>}
    {law.consensus > 0 && <><span class="sep">·</span><span>{law.consensus}-fold consensus</span></>}
    {law.specimen && <><span class="sep">·</span><span class="specimen-tag">specimen</span></>}
  </div>

  <section class="law-section">
    <h3 class="law-h">Enuntiatio — the claim</h3>
    <p class="claim">{law.statement}</p>
    {law.falsifiable_claim && (
      <p class="falsifiable"><span class="label">Refuted by</span> {law.falsifiable_claim}</p>
    )}
  </section>

  <section class="law-section">
    <h3 class="law-h">Expressio — the formal statement</h3>
    <pre class="lean"><code>{expressio}</code></pre>
  </section>

  <section class="law-section">
    <h3 class="law-h">Demonstratio — the kernel-checked proof</h3>
    <pre class="lean"><code>{law.proof_src || "(none)"}</code></pre>
  </section>

  <div class={`certificate ${verified ? "is-verified" : "is-unproven"}`}>
    <span class="qed">{law.qed}</span>
    <span class="cert-detail">
      kernel&nbsp;verified: <b>{String(verified)}</b>
      {verified && law.consensus > 0 && <> · {law.consensus} independent proofs</>}
    </span>
  </div>
</article>

<style>
  .law-meta {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: var(--space-6);
  }
  .specimen-tag { color: var(--accent); }
  .law-section { margin: var(--space-6) 0; }
  .law-h {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0 0 var(--space-3);
  }
  .claim {
    font-family: var(--font-serif);
    font-size: var(--fs-body-lg);
    line-height: var(--lh-relaxed);
    margin: 0;
  }
  .falsifiable {
    margin-top: var(--space-3);
    color: var(--ink-soft);
    font-size: var(--fs-body-sm);
  }
  .falsifiable .label {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-mono-sm);
    color: var(--rubric);
    margin-right: var(--space-2);
  }
  pre.lean {
    font-family: var(--font-mono);
    font-size: var(--fs-mono-lg);
    line-height: var(--lh-normal);
    background: var(--paper-shade);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--rubric);
    border-radius: 4px;
    padding: var(--space-4) var(--space-5);
    overflow-x: auto;
    color: var(--ink);
    white-space: pre;
  }
  pre.lean code { font-family: inherit; }
  .certificate {
    margin-top: var(--space-8);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--rule);
    border-radius: 4px;
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    background: color-mix(in srgb, var(--mint) 10%, var(--paper));
  }
  .certificate.is-unproven { background: color-mix(in srgb, var(--rubric) 8%, var(--paper)); }
  .qed {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--fs-body-lg);
    color: var(--mint);
  }
  .certificate.is-unproven .qed { color: var(--rubric); }
  .cert-detail {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    color: var(--ink-soft);
  }
</style>
