---
/**
 * SystemMap — hand-authored, data-driven SVG of Leibniz's pipeline and trust
 * boundary. Every colour is a CSS variable, so it re-skins with the vellum/ink
 * toggle; box/text sizes are authored (no font-metric clipping); no build
 * toolchain. The shape encodes the charter: LLMs PROPOSE (left, untrusted),
 * mechanical checkers DECIDE (centre, the boundary), the ledger PUBLISHES (right).
 */
const W = 1080;
const H = 600;

type Node = { id: string; x: number; y: number; w: number; h: number; t: string; s: string[]; kind?: "accent" | "mint" };
const nodes: Node[] = [
  { id: "survey",     x: 60,  y: 80,  w: 240, h: 64, t: "SURVEY", s: ["frontier + cross-domain analogy"] },
  { id: "conjecture", x: 60,  y: 190, w: 240, h: 64, t: "CONJECTURE", s: ["an LLM proposes a claim"] },
  { id: "formalize",  x: 60,  y: 300, w: 240, h: 64, t: "FORMALIZE", s: ["autoformalizer → Lean statement"] },
  { id: "gates",      x: 420, y: 80,  w: 250, h: 92, t: "Cheap gates — mechanical", s: ["Z3 refute · novelty corpus", "faithfulness · before proof compute"], kind: "accent" },
  { id: "kernel",     x: 420, y: 300, w: 250, h: 92, t: "Lean kernel — the decider", s: ["N+1 consensus · MECHANICAL", "sets kernel_verified · stamps Q.E.D."], kind: "accent" },
  { id: "promulgate", x: 800, y: 110, w: 230, h: 64, t: "PROMULGATE", s: ["only on a real kernel Q.E.D."] },
  { id: "codex",      x: 800, y: 240, w: 230, h: 64, t: "Codex", s: ["promulgated laws"] },
  { id: "site",       x: 800, y: 430, w: 230, h: 86, t: "Codex Calculemus", s: ["this site · operator-published", "promotion ≠ publication"], kind: "mint" },
];

const clusters = [
  { x: 36,  y: 50,  w: 288, h: 336, t: "proposal — LLMs propose · untrusted" },
  { x: 400, y: 50,  w: 290, h: 372, t: "trust boundary — mechanical checkers decide" },
  { x: 780, y: 84,  w: 270, h: 452, t: "the ledger" },
];

type Edge = { d: string; label?: string; lx?: number; ly?: number; dashed?: boolean };
const edges: Edge[] = [
  { d: "M180,144 L180,190" },
  { d: "M180,254 L180,300" },
  { d: "M300,332 C360,332 360,126 420,126", label: "cheap gates first", lx: 360, ly: 232 },
  { d: "M545,172 L545,300", label: "survivors → DERIVE", lx: 545, ly: 236 },
  { d: "M670,346 C740,346 740,142 800,142", label: "kernel Q.E.D.", lx: 735, ly: 250 },
  { d: "M915,174 L915,240" },
  { d: "M915,304 L915,430", label: "operator publish", lx: 915, ly: 367 },
  { d: "M545,392 C320,452 180,420 180,254", label: "quarantine → KFM re-seed", lx: 350, ly: 452, dashed: true },
];

const lineH = 16;
const chipW = (s: string) => s.length * 6.1 + 16;
---

<svg class="ingegno-diagram sysmap" viewBox={`0 0 ${W} ${H}`} role="img" aria-label="System map: proposal, trust boundary, and the ledger" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <marker id="sm-arrow" markerUnits="userSpaceOnUse" markerWidth="12" markerHeight="12" viewBox="0 0 12 12" refX="10" refY="6" orient="auto">
      <path d="M1,1 L11,6 L1,11 z" class="sm-arrowhead" />
    </marker>
  </defs>

  {clusters.map((c) => (
    <g class="sm-cluster">
      <rect x={c.x} y={c.y} width={c.w} height={c.h} rx="8" />
      <text x={c.x + c.w / 2} y={c.y + 22} text-anchor="middle" class="sm-cluster-title">{c.t}</text>
    </g>
  ))}

  {edges.map((e) => (
    <g class="sm-edge">
      <path d={e.d} class={e.dashed ? "sm-path sm-path--dashed" : "sm-path"} marker-end="url(#sm-arrow)" />
      {e.label && (
        <g>
          <rect x={(e.lx ?? 0) - chipW(e.label) / 2} y={(e.ly ?? 0) - 9} width={chipW(e.label)} height="18" rx="3" class="sm-elabel-bg" />
          <text x={e.lx} y={e.ly} text-anchor="middle" dominant-baseline="central" class="sm-elabel">{e.label}</text>
        </g>
      )}
    </g>
  ))}

  {nodes.map((n) => {
    const lines = [{ t: n.t, cls: "sm-t" }, ...n.s.map((s) => ({ t: s, cls: "sm-s" }))];
    const cx = n.x + n.w / 2;
    const y0 = n.y + n.h / 2 - ((lines.length - 1) * lineH) / 2;
    return (
      <g class={`sm-node ${n.kind ?? ""}`}>
        <rect x={n.x} y={n.y} width={n.w} height={n.h} rx="6" />
        {lines.map((ln, i) => (
          <text x={cx} y={y0 + i * lineH} text-anchor="middle" dominant-baseline="central" class={ln.cls}>{ln.t}</text>
        ))}
      </g>
    );
  })}
</svg>

<style>
  .sysmap { display: block; max-width: 100%; height: auto; }
  .sm-cluster rect { fill: color-mix(in srgb, var(--accent) 6%, transparent); stroke: var(--rule); stroke-width: 1; }
  .sm-cluster-title { font-family: var(--font-serif); font-style: italic; font-size: 15px; fill: var(--ink-soft); }
  .sm-path { fill: none; stroke: var(--accent); stroke-width: 1.4; }
  .sm-path--dashed { stroke-dasharray: 4 4; }
  .sm-arrowhead { fill: var(--accent); }
  .sm-elabel-bg { fill: var(--paper); }
  .sm-elabel { font-family: var(--font-mono); font-size: 11px; fill: var(--ink-soft); }
  .sm-node rect { fill: var(--paper-shade); stroke: var(--accent); stroke-width: 1.25; }
  .sm-t { font-family: var(--font-sans); font-weight: 600; font-size: 15px; fill: var(--ink); }
  .sm-s { font-family: var(--font-sans); font-size: 12px; fill: var(--ink-soft); }
  .sm-node.accent rect { stroke: var(--rubric); fill: color-mix(in srgb, var(--rubric) 9%, var(--paper)); }
  .sm-node.accent .sm-t { fill: var(--rubric); }
  .sm-node.mint rect { stroke: var(--mint); fill: color-mix(in srgb, var(--mint) 13%, var(--paper)); }
</style>
