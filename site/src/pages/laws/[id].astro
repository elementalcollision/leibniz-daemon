---
import Page from "../../layouts/Page.astro";
import LawFolio from "../../components/LawFolio.astro";
import Marginalia from "../../components/Marginalia.astro";
import { getCollection } from "astro:content";
import { claimLabel, figureFor, formatStamp } from "../../lib/format";

export async function getStaticPaths() {
  const items = (await getCollection("laws")).sort((a, b) => a.id.localeCompare(b.id));
  return items.map((entry, i) => ({
    params: { id: entry.id },
    props: { entry, prev: items[i - 1] ?? null, next: items[i + 1] ?? null },
  }));
}

const { entry, prev, next } = Astro.props;
const fig = figureFor(entry.id);
---
<Page title={`${entry.data.statement} — Codex Calculemus`} description={entry.data.statement}>
  <article class="folio">
    <a class="back-link" href="/laws">← Le Leggi</a>
    <div class="eyebrow" style="margin-top:var(--space-5)">
      <span class="rubric">{claimLabel(entry.data.claim_type)}</span>
      {entry.data.published_at && <><span class="sep">·</span>{formatStamp(entry.data.published_at)}</>}
    </div>
    <h1 class="page-title">{entry.data.statement}</h1>

    <LawFolio law={entry.data} />

    <Marginalia id={fig.id} caption={fig.caption} />

    <nav class="reader-foot">
      {prev ? <a href={`/laws/${prev.id}`}>← {prev.data.statement}</a> : <span aria-disabled="true">← earlier</span>}
      <a href="/laws">index</a>
      {next ? <a href={`/laws/${next.id}`}>{next.data.statement} →</a> : <span aria-disabled="true">later →</span>}
    </nav>
  </article>
</Page>
