---
import Page from "../layouts/Page.astro";
import Ornament from "../components/Ornament.astro";
import { getCollection } from "astro:content";
import { formatStamp } from "../lib/format";

const laws = (await getCollection("laws")).sort((a, b) => (b.data.published_at || "").localeCompare(a.data.published_at || ""));
const cycles = (await getCollection("cycles")).sort((a, b) => b.data.cycle - a.data.cycle);
const latest = laws[0];

const sections = [
  { href: "/laws", num: laws.length, it: "Le Leggi", en: "The Laws",
    desc: "Theorems settled by calculation — each with its claim, its formal statement, and the kernel-checked proof that earned its Q.E.D." },
  { href: "/cycles", num: cycles.length, it: "Il Lavoro", en: "The Work",
    desc: "The daemon's circadian cycles — what it surveyed, conjectured, and where each candidate came to rest." },
];
---
<Page title="Codex Calculemus — Leibniz's ledger of theorems">
  <article class="folio">
    <Ornament />
    <div class="eyebrow">CODEX CALCULEMUS <span class="sep">·</span> CALCULEMUS</div>
    <h1 class="page-title">Codex Calculemus</h1>
    <p class="subtitle">— the ledger of theorems settled by calculation —</p>
    <p class="lede">
      <em>Calculemus.</em> When two minds disagree, said Leibniz, let them not
      quarrel but calculate. This is the reading-room of a daemon that takes him
      at his word: it proposes conjectures, formalizes them in the
      <em>characteristica</em> — Lean — and asks the kernel to <em>decide</em>.
      An LLM may propose; only the kernel, and Z3, may judge. What appears here
      carries a real, machine-checked <span class="rubric">Q.E.D.</span> — nothing
      less is admitted.
    </p>

    {latest && (
      <p class="eyebrow" style="margin-top:var(--space-6)">
        <span class="live-dot"></span>LATEST <span class="sep">·</span>
        <span class="rubric">{latest.data.statement}</span>
        {latest.data.published_at && <><span class="sep">·</span>{formatStamp(latest.data.published_at)}</>}
      </p>
    )}

    <nav class="toc">
      {sections.map((s) => (
        <a class="toc-card" href={s.href}>
          <div class="num">{String(s.num).padStart(2, "0")}</div>
          <h3>{s.it}</h3>
          <div class="eyebrow">{s.en}</div>
          <p style="margin-top:var(--space-3)">{s.desc}</p>
        </a>
      ))}
    </nav>

    <div class="apparatus">
      <a href="/architecture">
        <span class="eyebrow">L'INGEGNO <span class="sep">·</span> THE WORKINGS</span>
        <span class="label-it">How a law is earned</span><span class="desc"> — the pipeline and the trust boundary behind the ledger.</span>
      </a>
      <a href="/colophon">
        <span class="eyebrow">COLOPHON <span class="sep">·</span> ON THE MAKING</span>
        <span class="label-it">What is published &amp; withheld</span><span class="desc"> — provenance, the publish gate, and what is held back.</span>
      </a>
    </div>
  </article>
</Page>
