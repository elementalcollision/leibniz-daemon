---
import Page from "../../layouts/Page.astro";
import Marginalia from "../../components/Marginalia.astro";
import { getCollection } from "astro:content";
import { figureFor, formatStamp, titleCase } from "../../lib/format";

export async function getStaticPaths() {
  const cycles = (await getCollection("cycles")).sort((a, b) => a.data.cycle - b.data.cycle);
  return cycles.map((entry, i) => ({
    params: { id: entry.id },
    props: { entry, prev: cycles[i - 1] ?? null, next: cycles[i + 1] ?? null },
  }));
}

const { entry, prev, next } = Astro.props;
const d = entry.data;
const fig = figureFor(entry.id);
const stats = [
  ["seeds", d.seeds],
  ["conjectured", d.conjectured],
  ["reached proof", d.reached_proof],
  ["promulgated", d.promulgated],
];
const reasons = Object.entries(d.by_reason || {}).sort((a, b) => b[1] - a[1]);
---
<Page title={`Cycle ${d.cycle} — Il Lavoro — Codex Calculemus`} description={d.summary}>
  <article class="folio">
    <a class="back-link" href="/cycles">← Il Lavoro</a>
    <div class="eyebrow" style="margin-top:var(--space-5)">
      <span class="rubric">CYCLE {d.cycle}</span>
      {d.created_at && <><span class="sep">·</span>{formatStamp(d.created_at)}</>}
      {d.domain && <><span class="sep">·</span>{d.domain.replace(/_/g, " ").toUpperCase()}</>}
      {d.illustrative && <><span class="sep">·</span><span class="illustrative-tag">ILLUSTRATIVE</span></>}
    </div>
    <h1 class="page-title">Ciclo {d.roman || d.cycle}</h1>

    {d.illustrative && (
      <p class="illustrative-note">
        This is an <strong>illustrative</strong> cycle showing the work-log format —
        not a record of real daemon output.
      </p>
    )}
    {d.summary && <p class="lede">{d.summary}</p>}

    <div class="ledger-stats">
      {stats.map(([label, n]) => (
        <div class="stat"><div class="stat-n">{n}</div><div class="stat-l">{label}</div></div>
      ))}
    </div>

    {reasons.length > 0 && (
      <section style="margin-top:var(--space-8)">
        <h3 class="law-h">Dispositions — where candidates came to rest</h3>
        <ul class="reason-list">
          {reasons.map(([reason, n]) => (
            <li><span class="reason-n">{n}</span><span class="reason-name">{titleCase(reason)}</span></li>
          ))}
        </ul>
      </section>
    )}

    <Marginalia id={fig.id} caption={fig.caption} />

    <nav class="reader-foot">
      {prev ? <a href={`/cycles/${prev.id}`}>← Cycle {prev.data.cycle}</a> : <span aria-disabled="true">← earlier</span>}
      <a href="/cycles">index</a>
      {next ? <a href={`/cycles/${next.id}`}>Cycle {next.data.cycle} →</a> : <span aria-disabled="true">later →</span>}
    </nav>
  </article>
</Page>

<style>
  .law-h {
    font-family: var(--font-mono); font-size: var(--fs-mono);
    letter-spacing: var(--ls-eyebrow); text-transform: uppercase;
    color: var(--ink-faint); margin: 0 0 var(--space-4);
  }
  .ledger-stats {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-4);
    margin-top: var(--space-6);
  }
  .stat {
    border: 1px solid var(--rule); border-radius: 4px;
    padding: var(--space-4); text-align: center;
    background: var(--paper-shade);
  }
  .stat-n { font-family: var(--font-serif); font-size: var(--fs-title); line-height: 1; color: var(--rubric); }
  .stat-l { font-family: var(--font-mono); font-size: var(--fs-mono-sm); letter-spacing: var(--ls-eyebrow); text-transform: uppercase; color: var(--ink-soft); margin-top: var(--space-2); }
  .reason-list { list-style: none; padding: 0; margin: 0; }
  .reason-list li { display: flex; align-items: baseline; gap: var(--space-3); padding: var(--space-2) 0; border-bottom: 1px solid var(--rule); }
  .reason-n { font-family: var(--font-mono); color: var(--rubric); min-width: 2ch; }
  .reason-name { font-family: var(--font-sans); }
  .illustrative-tag { color: var(--accent); }
  .illustrative-note {
    border: 1px solid var(--rule); border-left: 3px solid var(--accent);
    border-radius: 4px; padding: var(--space-3) var(--space-4);
    background: color-mix(in srgb, var(--accent) 7%, var(--paper));
    color: var(--ink-soft); font-size: var(--fs-body-sm); margin: var(--space-5) 0;
  }
  @media (max-width: 640px) { .ledger-stats { grid-template-columns: repeat(2, 1fr); } }
</style>
