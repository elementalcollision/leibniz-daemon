# Cloudflare Pages headers. Fingerprinted assets are immutable; fonts cache for
# a week; HTML is revalidated so newly published laws appear promptly.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
