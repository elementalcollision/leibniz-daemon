# Leibniz provider credentials (R4). Copy to .env (gitignored) and fill in.
# Secrets never get committed; .env is in .gitignore. DO NOT put real keys here.

# --- proposal roles: CONJECTURE / FORMALIZE (Anthropic direct) ---
ANTHROPIC_API_KEY=
# Optional model override (default claude-opus-4-8)
# LEIBNIZ_CONJECTURE_MODEL=claude-opus-4-8

# --- prover roles: PROOF_DRAFT (OpenRouter gateway) ---
OPENROUTER_API_KEY=
# Cascaded + witness prover ensemble (comma-separated model ids). The proof edge requires N+1
# INDEPENDENT kernel-verified proofs from DISTINCT voters (ADR 0006). N+1 keys identity on the model
# NAME sans `@gateway`, so `model@gateway` routes ONE model through a named gateway without changing the
# voter count (ADR 0028). Goedel-Prover-V2 32B and 8B are DIFFERENT names -> two distinct voters: listing
# both gives a 32B<->8B failover (if the 32B is cold/rate-limited on Featherless, the 8B still proposes,
# and vice versa) at no extra cost, since Featherless is flat-rate. Every draft is still kernel-re-verified.
LEIBNIZ_PROVER_MODELS=deepseek/deepseek-prover-v2,Goedel-LM/Goedel-Prover-V2-32B@featherless,Goedel-LM/Goedel-Prover-V2-8B@featherless,anthropic/claude-opus-4-8
# N+1 consensus threshold (number of distinct kernel-verified proofs required).
LEIBNIZ_PROOF_CONSENSUS=2

# --- ADR 0028 per-model gateway routing: @featherless targets Featherless (flat-rate, OpenAI-compatible) ---
# FEATHERLESS_API_KEY=
# LEIBNIZ_GATEWAY_FEATHERLESS_URL=https://api.featherless.ai/v1/chat/completions
# LEIBNIZ_GATEWAY_FEATHERLESS_KEY_ENV=FEATHERLESS_API_KEY

# --- optional: hosted prover via a raw HTTP endpoint instead of OpenRouter ---
# LEIBNIZ_PROVER_URL=
# LEIBNIZ_PROVER_KEY=
