# Leibniz UAT deploy profile (ADR 0033). Copy to deploy/profiles/uat.env and adjust.
# Run this from the SEPARATE leibniz-uat/ checkout (see UAT_PLAN.md). This profile sets only
# LEIBNIZ_* deploy knobs; CREDENTIALS live in the UAT checkout's gitignored .env and MUST be
# separately-scoped keys (independent budget = the blast-radius boundary).
#
# UAT soaks new `main` on a faster, higher-cap cadence and MAY pin an experimental kernel/corpus.

LEIBNIZ_INSTANCE=uat

# State — SEPARATE ledger + frontier + notebook. Never the prod `.leibniz/` dir. The runtime
# write-barrier fails closed if these collide with prod; the launch guard catches it earlier.
LEIBNIZ_RUNTIME_DB=.leibniz-uat/memory.db
LEIBNIZ_FRONTIER_PATH=.leibniz-uat/frontier.json
LEIBNIZ_NOTEBOOK_PATH=.leibniz-uat/notebook.json

# UAT must NOT publish to the prod Codex. If exporting at all, use a UAT-scoped scratch ledger.
LEIBNIZ_LEDGER=../codex-calculemus-uat

# UAT may pin an experimental Lean image / corpus (honoured for uat; refused for prod).
# LEIBNIZ_LEAN_IMAGE=leibniz-lean:v4.32.0-rc
# LEIBNIZ_LEAN_REPL_IMAGE=leibniz-lean-repl:v4.32.0-rc
# LEIBNIZ_CORPUS_PATH=corpus/known_results.experimental.json

# Cost / cadence — higher cap, faster cycles for soak throughput.
LEIBNIZ_DAILY_USD_CAP=40
LEIBNIZ_PROOF_CONSENSUS=2
LEIBNIZ_PROOF_REPAIR=1
