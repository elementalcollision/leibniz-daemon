# Leibniz PROD deploy profile (ADR 0033). Copy to deploy/profiles/prod.env and adjust.
# This profile sets only LEIBNIZ_* deploy knobs; CREDENTIALS live in this checkout's
# gitignored .env (loaded by the entrypoint), never here and never committed.
#
# PROD pins the audited Lean image + corpus IN CODE and REFUSES experimental overrides
# (ADR 0033 Slice 3) — do NOT set LEIBNIZ_LEAN_IMAGE / LEIBNIZ_CORPUS_PATH here; bump the
# code default to move the pin (a reviewed, auditable change).

LEIBNIZ_INSTANCE=prod

# State — the production ledger + frontier + notebook (the accumulating Codex source).
LEIBNIZ_RUNTIME_DB=.leibniz/memory.db
LEIBNIZ_FRONTIER_PATH=.leibniz/frontier.json
LEIBNIZ_NOTEBOOK_PATH=.leibniz/notebook.json

# Published Codex ledger (export target for scripts/export_calculemus.py). The publish guard
# already restricts publication to the prod instance; keep this pointed at the real Codex.
LEIBNIZ_LEDGER=../codex-calculemus

# Cost / cadence — conservative.
LEIBNIZ_DAILY_USD_CAP=20
LEIBNIZ_PROOF_CONSENSUS=2
LEIBNIZ_PROOF_REPAIR=1
