# Leibniz DEV deploy profile (ADR 0033). Copy to deploy/profiles/dev.env and adjust.
# Local development / throwaway experiments. Credentials via this checkout's gitignored .env.

LEIBNIZ_INSTANCE=dev

# State — a separate dev dir, never the prod `.leibniz/`.
LEIBNIZ_RUNTIME_DB=.leibniz-dev/memory.db
LEIBNIZ_FRONTIER_PATH=.leibniz-dev/frontier.json
LEIBNIZ_NOTEBOOK_PATH=.leibniz-dev/notebook.json

# Cost — small cap; dev rarely runs the full ladder.
LEIBNIZ_DAILY_USD_CAP=5
LEIBNIZ_PROOF_CONSENSUS=2
